DB_HOST=mariadb
DB_PORT=3306
DB_NAME=marunage2
DB_USER=marunage
HEALTHCHECK_TIMEOUT_SEC=5
LOG_LEVEL=INFO
WORKSPACE_PATH=/workspace
TARGET_REPO=your-org/your-repo
TARGET_REF=main
HOST_COPILOT_CONFIG_DIR=/absolute/path/to/copilot-config
COPILOT_CONFIG_DIR=/run/copilot
DOCKER_SOCK=/var/run/docker.sock
REQUIRED_ENV_VARS=DB_HOST,DB_PORT,DB_NAME,DB_USER,DB_PASSWORD
